# Application
APP_NAME=Team Report Management System
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/team_reports_db

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Admin Bootstrap
ADMIN_BOOTSTRAP_EMAIL=admin@company.com

# AI (Optional)
OPENAI_API_KEY=sk-your-key-here
