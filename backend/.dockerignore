# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.venv/
env/

# Environment variables (injected by Docker Compose)
.env

# Testing & Linting caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Distribution
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Documentation (not needed in container)
*.md

# SQLite (dev-only fallback)
*.db
*.sqlite3

# OS files
.DS_Store
Thumbs.db
